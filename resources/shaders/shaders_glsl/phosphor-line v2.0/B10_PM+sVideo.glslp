shaders = "4"

shader0 = "passes/dither-filter.glsl"
shader1 = "passes/CA-sharpen.glsl"
scale_type1 = "source"
scale1 = "1.000000"


shader2 = "../stock.glsl"
filter_linear2 = "false"
scale_type_x2 = "source"
scale_x2 = "1.000000"
scale_type_y2 = "source"
scale_y2 = "2.000000"

shader3 = "passes/shadowmask.glsl"
filter_linear3 = "true"

parameters = "NTSCintensity; GAMMA;HT;HEADER;SAT;BLK;EXPOSURE;CT;CORNER;CPOY;PPOY;MASK_INTENSITY;MASK_TYPE;MASK_SIZE"

NTSCintensity = "1.000000"

GAMMA = "2.0"